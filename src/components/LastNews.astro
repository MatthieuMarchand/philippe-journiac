---
import { getCollection } from "astro:content";

const actualites = await getCollection("actualites");

const actualitesRecentes = actualites
  .sort((a, b) => b.data.publish_at.valueOf() - a.data.publish_at.valueOf())
  .slice(0, 3);
---

<section id="actualites">
    <h2>Dernières actualités</h2>

    <ul>
        {
            actualitesRecentes.map((item) => (
                <li>
                    <a href={`/actualites/${item.id}`}>
                        <article>
                            <div class="image-container">
                                <img src=`/content${item.data.image}` alt=`${item.data.title}` >
                            </div>

                            <div class="content">
                                <h3>{item.data.title}</h3>

                                <p>Découvrir l'actualité <span>-></span></p>
                            </div>

                        </article>
                    </a>
                </li>
            ))
        }
    </ul>
</section>

<style lang="scss">
	section#actualites {
		margin-top: 5rem;

		h2 {
			@include font-title();
		}

		ul {
			display: flex;
			gap: 1rem;
			margin-top: 1rem;

			li {
				padding: 1rem;
				flex: 1;
				background: $color-secondary;
				border-radius: 1rem;
                border: solid .25rem rgba($color-primary, 0);
                transition: .5s;

                &:hover {
                    border: solid .25rem rgba($color-primary, 1);

                    article div.content p span {
                        opacity: 1;
                    }
                }

                article {
                    height: 100%;
                    display: flex;
                    flex-direction: column;
                    gap: 1rem;

                    div.image-container {
                        aspect-ratio: 4 / 3;
                        overflow: hidden;

                        img {
                            width: 100%;
                            height: 100%;
                            object-fit: cover;
                        }
                    }

                    div.content {
                        display: flex;
                        flex-direction: column;
                        justify-content: space-between;
                        gap: 1rem;
                        flex: 1;

                        h3 {
                            font-family: $fontface-semibold;
                        }

                        p{
                            font-family: $fontface-semibold;
                            
                            span {
                                opacity: 0;
                                transition: 0.5s;
                            }
                        }
                    }

                }
			}
		}

	}
</style>