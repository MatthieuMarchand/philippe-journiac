<script>
  import Lenis from 'lenis'

  let lenis;

  function initLenis() {
    if (lenis) {
      lenis.destroy();
    }

    lenis = new Lenis({
      duration: 1.5,
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      wheelMultiplier: 1,
      infinite: false,
    });

    lenis.scrollTo(0, { immediate: true });

    function raf(time) {
      lenis.raf(time);
      requestAnimationFrame(raf);
    }

    requestAnimationFrame(raf);
  }

  document.addEventListener('astro:page-load', initLenis);
</script>