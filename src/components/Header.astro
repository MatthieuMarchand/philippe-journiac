<header>
    <h2><a href="/">Philippe Journiac</a></h2>

    <nav>
        <a href="/tableaux">Galerie</a>
        <a href="/actualites">Actualités</a>
        <a class="btn-contact" href="/contact">Contact</a>
    </nav>
</header>

<style lang="scss">
    header {
        position: fixed;
        top: 0;
        width: 100%;
        padding: 2rem 8rem;
        box-sizing: border-box;
        display: flex;
        justify-content: space-between;
        align-items: center;
        z-index: 1;
        transition: background .5s;

        @include respond-to("tablet") {
            padding: 2rem 4rem;
        }
        
        @include respond-to("mobile") {
            padding: 1rem 2rem;
        }

        &.scrolled {
            background: $color-white;
        }

        h2 * {
			@include font-title(24);
        }

        nav {
            display: flex;
            align-items: center;
            gap: 2rem;
            color: $color-primary;
            font-family: $fontface-medium;

            @include respond-to("tablet") {
                display: none;
            }

            .btn-contact {
                background: $color-primary;
                color: $color-white;
                padding: .5rem;
            }
        }
    }
</style>

<script>
  const header = document.querySelector('header');

  window.addEventListener('scroll', () => {
    if (!header) return;

    if (window.scrollY > 0) {
      header.classList.add('scrolled');
    } else {
      header.classList.remove('scrolled');
    }
  });
</script>