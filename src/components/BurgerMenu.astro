<button id="burger">
    <div>
        <div></div>
        <div></div>
        <div></div>
    </div>
</button>

<section id="section-burger">
    <nav>
        <a href="/galerie">Galerie</a>
        <a href="/actualites">Actualités</a>
        <a href="/contact">Contact</a>
    </nav>
</section>

<script>
    function initBurger() {
        console.log("coucou");
        const buttonBurger = document.querySelector("#burger");
        const sectionBurger = document.querySelector("#section-burger");

        buttonBurger?.addEventListener("click", () => {
            if (!sectionBurger) {
                return;
            }

            if (buttonBurger.classList.contains("actived")) {
                buttonBurger.classList.remove("actived");
                sectionBurger.classList.remove("actived");
            } else {
                buttonBurger.classList.add("actived");
                sectionBurger.classList.add("actived");
            }
        });
    }

    document.addEventListener("astro:page-load", initBurger);
</script>

<style lang="scss">
    button {
        border: unset;
        background: unset;
        padding: 0.25rem;
        cursor: pointer;
        display: none;
        z-index: 2;

        @include respond-to("tablet") {
            display: unset;
        }

        &.actived {
            & > div {
                div:nth-child(1) {
                    top: calc(50% - 1px);
                    transform: rotateZ(45deg);
                }

                div:nth-child(2) {
                    opacity: 0;
                }

                div:nth-child(3) {
                    bottom: calc(50% - 1px);
                    transform: rotateZ(-45deg);
                }
            }
        }

        & > div {
            position: relative;
            width: 2rem;
            height: 1.5rem;

            div {
                position: absolute;
                height: 2px;
                width: 100%;
                background: $color-primary;
                @extend %transition;

                &:nth-child(1) {
                    top: 0;
                }

                &:nth-child(2) {
                    top: calc(50% - 1px);
                }

                &:nth-child(3) {
                    bottom: 0;
                }
            }
        }
    }

    section {
        position: fixed;
        top: 0;
        left: 0;
        height: 100dvh;
        width: 100%;
        background: $color-white;
        z-index: 1;
        visibility: hidden;
        opacity: 0;
        @extend %transition;

        &.actived {
            visibility: visible;
            opacity: 1;
        }

        nav {
            height: 100%;
            width: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 3rem;

            a {
                @include font-title();
                font-size: 24px;
            }
        }
    }
</style>
