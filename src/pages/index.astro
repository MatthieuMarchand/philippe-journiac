---
import Layout from "../layouts/Layout.astro";

import { getCollection } from "astro:content";

const articles = await getCollection("articles");
---

<Layout>
	<ul>
		{
			articles.map((item) => (
				<li>
					<p>{item.data.title}</p>
					<p>{item.data.content}</p>
				</li>
			))
		}
	</ul>
</Layout>