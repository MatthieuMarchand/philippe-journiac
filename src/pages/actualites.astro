---
import Layout from "../layouts/Layout.astro";

import { getCollection } from "astro:content";

const actualites = await getCollection("actualites");
---

<Layout>
    <main>
        <h1>Actualités</h1>

        <section>
            <ul>
                {
                    actualites.map((item) => (
                        <li>
                            <a href=`/actualites/${item.id}` >
                                <article>
                                    <div class="image-container">
                                        <img src=`/content${item.data.image}` alt=`${item.data.title}` >
                                    </div>

                                    <div class="infos">
                                        <h2>{item.data.title}</h2>
                                        <p>{item.data.publish_at.toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' })}</p>
                                    </div>
                                </article>
                            </a>
                        </li>
                    ))
                }
            </ul>
        </section>
    </main>
</Layout>

<style lang="scss">
    h1 {
        margin-top: 8rem;
        font-size: 64px;
        font-weight: bold;
    }

    section {
        margin-top: 4rem;
        
        ul {
            display: flex;
            flex-wrap: wrap;
            gap: 5rem 3rem;

            li {
                flex: 0 0 calc(50% - 1.5rem);

                &:hover img {
                    transform: scale(1.1);
                }

                div.image-container {
                    width: 100%;
                    aspect-ratio: 4 / 3;
                    overflow: hidden;

                    img {
                        width: 100%;
                        height: 100%;
                        object-fit: cover;
                        transition: transform 0.5s ease;
                    }
                }

                div.infos {
                    margin-top: 2rem;
                    display: flex;
                    justify-content: space-between;

                    h2 {
                        font-family: $fontface-semibold;
                        font-size: $fontsize-secondary;
                    }
                }
            }
        }
    }
</style>