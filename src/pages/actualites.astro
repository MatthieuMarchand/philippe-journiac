---
import Layout from "../layouts/Layout.astro";

import { getCollection } from "astro:content";

const actualites = await getCollection("actualites");
---

<Layout pageTitle="Actualités">
    <main>
        <section>
            <h1>Actualités</h1>

            <ul>
                {
                    actualites
                        .sort((a, b) => b.data.publish_at.getTime() - a.data.publish_at.getTime())
                        .map((item) => (
                        <li>
                            <p>{item.data.publish_at.toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' })}</p>

                            <a href=`/actualites/${item.id}` >
                                <article>
                                    <h2>{item.data.title}</h2>

                                    <p>{item.data.lede}</p>

                                    <div class="image-container">
                                        <img src=`/content${item.data.image}` alt=`${item.data.title}` >
                                    </div>
                                </article>
                            </a>
                        </li>
                    ))
                }
            </ul>
        </section>
    </main>
</Layout>

<style lang="scss">
    section {
        h1 {
            @include font-title();
            margin-top: 8rem;
        }

        ul {
            margin-top: 1rem;
            display: flex;
            flex-direction: column;
            gap: 4rem;

            li {
                display: flex;
                justify-content: space-between;

                @include respond-to("tablet") {
                    flex-direction: column;
                }

                a {
                    width: calc(100% * 6 / 12);

                    @include respond-to("desktop") {
                        width: calc(100% * 8 / 12);
                    }

                    @include respond-to("tablet") {
                        width: 100%;
                        margin-top: .5rem;
                    }

                    &:hover article {
                        border: solid .25rem rgba($color-primary, 1);
                    }

                    article {
                        padding: 1rem;
                        background: $color-secondary;
                        border-radius: .5rem;
                        display: flex;
                        flex-direction: column;
                        gap: .5rem;
                        border: solid .25rem rgba($color-primary, 0);
                        @extend %transition;

                        h2 {
                            font-family: $fontface-semibold;
                        }

                        p {
                            font-family: $fontface-medium;
                            color: $color-gray;
                            display: -webkit-box;
                            -webkit-line-clamp: 3;
                            -webkit-box-orient: vertical;
                            overflow: hidden;
                        }

                        div.image-container {
                            aspect-ratio: 4 / 3;

                            img {
                                width: 100%;
                                height: 100%;
                                object-fit: cover;
                            }
                        }
                    }
                }
            }
        }
    }
</style>